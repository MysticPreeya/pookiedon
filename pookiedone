<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Pookie Don</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(160deg,#ffe4f0,#fff0f8,#ffd6e7);font-family:Georgia,serif;overflow:hidden}
.hbg{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.hf{position:absolute;animation:fup 7s linear infinite;opacity:0}
@keyframes fup{0%{opacity:0;transform:translateY(0)}10%{opacity:0.5}90%{opacity:0.2}100%{opacity:0;transform:translateY(-100vh)}}
.page{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;padding:20px}
h1{font-family:Georgia,serif;font-size:36px;color:#c0185a;font-weight:900;letter-spacing:1px;margin-bottom:4px}
.sub{font-size:13px;color:#e879a0;font-family:Arial,sans-serif;margin-bottom:18px}
.card{background:white;border-radius:24px;border:2px solid #fbb6ce;width:340px;padding:24px 20px 20px;display:flex;flex-direction:column;align-items:center;position:relative}
.card-hearts{position:absolute;top:14px;right:16px;font-size:13px;color:#fbb6ce;display:flex;gap:6px}
.cat-svg-wrap{width:240px;height:260px;position:relative;cursor:pointer;flex-shrink:0}

/* ENVELOPE STAGE - clips letter until open */
.env-stage{position:relative;width:200px;height:140px;margin-top:-20px;z-index:5;overflow:hidden}
.env-stage.open{overflow:visible}

.renv{position:absolute;inset:0;width:200px;height:140px}
.env-bg{position:absolute;inset:0;background:#e53e3e;border-radius:6px 6px 14px 14px;border:2px solid #c53030;z-index:1}
.env-vl{position:absolute;top:0;left:0;width:0;height:0;border-style:solid;border-width:70px 0 70px 100px;border-color:transparent transparent transparent #c53030;z-index:2}
.env-vr{position:absolute;top:0;right:0;width:0;height:0;border-style:solid;border-width:70px 100px 70px 0;border-color:transparent #c53030 transparent transparent;z-index:2}
.env-vb{position:absolute;bottom:0;left:0;width:0;height:0;border-style:solid;border-width:0 0 72px 200px;border-color:transparent transparent #b91c1c transparent;z-index:3}
.env-flap{position:absolute;top:0;left:0;width:0;height:0;border-style:solid;border-width:75px 100px 0 100px;border-color:#f87171 transparent transparent transparent;z-index:10;transform-origin:top center;transition:transform 0.7s cubic-bezier(.4,0,.2,1)}
.env-seal{position:absolute;top:45px;left:50%;transform:translateX(-50%);width:32px;height:32px;background:#fbbf24;border-radius:50%;border:2px solid #f59e0b;display:flex;align-items:center;justify-content:center;font-size:15px;z-index:11;transition:opacity 0.3s}

/* LETTER - hidden inside envelope at start */
.letter{position:absolute;left:8px;right:8px;bottom:4px;height:270px;background:white;border-radius:12px;border:2px solid #fecaca;overflow:hidden;z-index:0;transform:translateY(0px);transition:transform 0.75s 0.3s cubic-bezier(0.15,0,0.05,1)}

.l-head{background:#fff5f7;padding:10px 12px 8px;border-bottom:1.5px dashed #fecaca;display:flex;align-items:center;gap:10px}
.av{width:52px;height:52px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2.5px solid #fca5a5}
.av img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block}
.lht{flex:1}
.llb{font-size:8px;color:#ef4444;font-weight:700;letter-spacing:1px;font-family:Arial,sans-serif;text-transform:uppercase;margin-bottom:2px}
.lnm{font-size:13px;color:#7f1d1d;font-family:Georgia,serif;font-weight:700}
.ltg{font-size:9px;color:#f87171;font-family:Arial,sans-serif}
.lhb{font-size:18px;color:#f472b6;flex-shrink:0}
.lbody{padding:10px 12px}
.ldt{font-size:9px;color:#fca5a5;font-family:Arial,sans-serif;text-align:right;margin-bottom:6px}
.lgr{font-size:11px;color:#ef4444;font-family:Georgia,serif;font-weight:700;margin-bottom:5px}
.lms{font-size:10.5px;color:#450a0a;line-height:1.75;font-family:Georgia,serif}
.lft{margin-top:8px;display:flex;align-items:center;justify-content:space-between}
.lsg{font-size:10px;color:#dc2626;font-family:Georgia,serif;font-style:italic}
.lhs{display:flex;gap:3px;font-size:12px}

/* OPEN STATE */
.env-stage.open .env-flap{transform:rotateX(180deg)}
.env-stage.open .env-seal{opacity:0}
.env-stage.open .letter{transform:translateY(-210px);z-index:20}

.tap-btn{margin-top:16px;background:linear-gradient(135deg,#f472b6,#e879a0);color:white;border:none;padding:10px 28px;border-radius:30px;font-size:13px;font-weight:700;font-family:Arial,sans-serif;cursor:pointer;letter-spacing:0.5px;box-shadow:0 4px 14px rgba(244,114,182,0.5)}
.tap-btn:active{transform:scale(0.97)}
.spk{position:absolute;font-size:14px;opacity:0;pointer-events:none;animation:spkpop 0.9s ease-out forwards}
@keyframes spkpop{0%{opacity:0;transform:scale(0) translateY(0)}40%{opacity:1;transform:scale(1.3) translateY(-12px)}100%{opacity:0;transform:scale(0.5) translateY(-32px)}}
</style>
</head>
<body>
<div class="hbg" id="hbg"></div>
<div class="page">
  <h1>Pookie Don</h1>
  <div class="sub">a little something for you &#128149;</div>
  <div class="card">
    <div class="card-hearts"><span>&#9829;</span><span>&#9829;</span></div>

    <div class="cat-svg-wrap" id="catWrap">
      <svg width="240" height="260" viewBox="0 0 240 260" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="120" cy="205" rx="75" ry="58" fill="#f9f9f9" stroke="#e8e0e0" stroke-width="1.5"/>
        <path d="M188 222 Q228 202 218 242 Q208 252 194 237" fill="#f0eded" stroke="#e0d8d8" stroke-width="1.5"/>
        <ellipse cx="120" cy="118" rx="72" ry="68" fill="#fafafa" stroke="#e8e0e0" stroke-width="1.5"/>
        <polygon points="58,72 44,30 88,60" fill="#fafafa" stroke="#e8e0e0" stroke-width="1.5"/>
        <polygon points="62,68 52,40 82,62" fill="#f9c8da"/>
        <polygon points="182,72 196,30 152,60" fill="#fafafa" stroke="#e8e0e0" stroke-width="1.5"/>
        <polygon points="178,68 188,40 158,62" fill="#f9c8da"/>
        <!-- left bow -->
        <ellipse cx="52" cy="30" rx="16" ry="10" fill="#f472b6" stroke="#e879a0" stroke-width="1" transform="rotate(-20,52,30)"/>
        <ellipse cx="40" cy="24" rx="14" ry="9" fill="#f472b6" stroke="#e879a0" stroke-width="1" transform="rotate(-20,40,24)"/>
        <circle cx="46" cy="27" r="5" fill="#fb7eb3"/>
        <!-- right bow -->
        <ellipse cx="188" cy="30" rx="16" ry="10" fill="#f472b6" stroke="#e879a0" stroke-width="1" transform="rotate(20,188,30)"/>
        <ellipse cx="200" cy="24" rx="14" ry="9" fill="#f472b6" stroke="#e879a0" stroke-width="1" transform="rotate(20,200,24)"/>
        <circle cx="194" cy="27" r="5" fill="#fb7eb3"/>
        <!-- eyes -->
        <ellipse cx="96" cy="115" rx="18" ry="20" fill="white" stroke="#333" stroke-width="1"/>
        <circle cx="96" cy="118" r="13" fill="#1a1a2e"/>
        <circle cx="91" cy="113" r="5" fill="white"/>
        <circle cx="100" cy="121" r="2.5" fill="white"/>
        <!-- wink right -->
        <path d="M142 110 Q152 105 162 110" stroke="#333" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M142 110 Q152 116 162 110" stroke="#333" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <!-- nose - clickable -->
        <ellipse id="catNose" cx="120" cy="138" rx="9" ry="6" fill="#f9a8c9" stroke="#f472b6" stroke-width="1.5" style="cursor:pointer"/>
        <path d="M112 145 Q120 152 128 145" stroke="#d97ba0" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <!-- whiskers -->
        <line x1="58" y1="136" x2="106" y2="139" stroke="#ccc" stroke-width="1"/>
        <line x1="56" y1="143" x2="106" y2="142" stroke="#ccc" stroke-width="1"/>
        <line x1="134" y1="139" x2="182" y2="136" stroke="#ccc" stroke-width="1"/>
        <line x1="134" y1="142" x2="184" y2="143" stroke="#ccc" stroke-width="1"/>
        <!-- paws -->
        <ellipse cx="80" cy="218" rx="22" ry="15" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1.5"/>
        <ellipse cx="160" cy="218" rx="22" ry="15" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1.5"/>
        <ellipse cx="68" cy="228" rx="7" ry="5" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1"/>
        <ellipse cx="80" cy="231" rx="7" ry="5" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1"/>
        <ellipse cx="92" cy="228" rx="7" ry="5" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1"/>
        <ellipse cx="148" cy="228" rx="7" ry="5" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1"/>
        <ellipse cx="160" cy="231" rx="7" ry="5" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1"/>
        <ellipse cx="172" cy="228" rx="7" ry="5" fill="#f5f5f5" stroke="#e0d8d8" stroke-width="1"/>
        <!-- blush -->
        <ellipse cx="78" cy="148" rx="14" ry="8" fill="#ffc0cb" opacity="0.4"/>
        <ellipse cx="162" cy="148" rx="14" ry="8" fill="#ffc0cb" opacity="0.4"/>
      </svg>
    </div>

    <!-- ENVELOPE STAGE -->
    <div class="env-stage" id="envStage">
      <div class="renv" id="renv">
        <!-- LETTER inside -->
        <div class="letter">
          <div class="l-head">
            <div class="av"><img id="photoImg" src="" alt="photo"/></div>
            <div class="lht">
              <div class="llb">a letter for</div>
              <div class="lnm">Pookiedone</div>
              <div class="ltg">my fav person &#10024;</div>
            </div>
            <div class="lhb">&#9829;</div>
          </div>
          <div class="lbody">
            <div class="ldt">June 27, 2026</div>
            <div class="lgr">Hey pookiedon,</div>
            <div class="lms">I hope you are good! Is your shifting completed? Just thinking... when are you going to bring idli for me? 😄</div>
            <div class="lft">
              <div class="lsg">Regards,
                Preeya&#9829;</div>
              <div class="lhs">
                <span style="color:#f472b6">&#9829;</span>
                <span style="color:#ef4444">&#9829;</span>
                <span style="color:#f472b6">&#9829;</span>
              </div>
            </div>
          </div>
        </div>
        <!-- envelope layers -->
        <div class="env-bg"></div>
        <div class="env-vl"></div>
        <div class="env-vr"></div>
        <div class="env-vb"></div>
        <div class="env-flap"></div>
        <div class="env-seal">&#9829;</div>
      </div>
    </div>

    <button class="tap-btn" id="tapBtn">&#10024; Tap the kitten nose</button>
  </div>
</div>

<script>

// Set photo
document.getElementById('photoImg').src = 'data:image/png;base64,';

var isOpen = false;

function tapNose() {
  var stage = document.getElementById('envStage');
  var btn = document.getElementById('tapBtn');
  if (!isOpen) {
    isOpen = true;
    stage.classList.add('open');
    btn.innerHTML = '&#128140; Tap again to close';
    spawnSparks();
  } else {
    isOpen = false;
    stage.classList.remove('open');
    btn.innerHTML = '&#10024; Tap the kitten nose';
  }
}

function spawnSparks() {
  var stage = document.getElementById('envStage');
  var items = ['&#10024;','&#9829;','&#127800;','&#10024;','&#9829;'];
  items.forEach(function(e, i) {
    var s = document.createElement('div');
    s.className = 'spk';
    s.innerHTML = e;
    s.style.cssText = 'position:absolute;font-size:14px;left:' + (10 + Math.random() * 170) + 'px;top:0;z-index:99;animation-delay:' + (i * 0.12) + 's';
    stage.appendChild(s);
    setTimeout(function() { if(s.parentNode) s.parentNode.removeChild(s); }, 1100);
  });
}

document.getElementById('tapBtn').addEventListener('click', tapNose);
document.getElementById('catWrap').addEventListener('click', tapNose);
document.getElementById('catNose').addEventListener('click', function(e) { e.stopPropagation(); tapNose(); });

// floating hearts
(function() {
  var bg = document.getElementById('hbg');
  var em = ['&#9829;','&#128149;','&#127800;','&#10024;'];
  setInterval(function() {
    var h = document.createElement('div');
    h.className = 'hf';
    h.innerHTML = em[Math.floor(Math.random() * em.length)];
    h.style.left = Math.random() * 100 + 'vw';
    h.style.bottom = '-20px';
    h.style.animationDuration = (5 + Math.random() * 4) + 's';
    h.style.fontSize = (11 + Math.random() * 12) + 'px';
    bg.appendChild(h);
    setTimeout(function() { if(h.parentNode) h.parentNode.removeChild(h); }, 9000);
  }, 800);
})();
</script>
</body>
</html>
